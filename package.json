{
  "name": "main",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "lint:eslint": "eslint --fix",
    "lint:prettier": "prettier --write \"**/*.{ts,tsx,mjs,js,css}\"",
    "lint:stylelint": "stylelint \"src/**/*.css\"",
    "lint:tsc": "tsc --noEmit",
    "lint": "concurrently --names \"prettier,eslint,stylelint,tsc\" --prefix-colors gray --pad-prefix --group \"yarn lint:prettier\" \"yarn lint:eslint\" \"yarn lint:stylelint\" \"yarn lint:tsc\"",
    "dev": "gatsby clean && gatsby develop",
    "prod": "gatsby clean && gatsby build && gatsby serve --port 8000",
    "build": "gatsby build --prefix-paths"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@fast-csv/format": "^5.0.5",
    "@types/babel__core": "^7.20.5",
    "@types/eslint": "^9.6.1",
    "@types/eslint__js": "^9.14.0",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-helmet": "^6.1.11",
    "@types/simple-oauth2": "^5.0.8",
    "@typescript-eslint/parser": "^8.58.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "gatsby-cli": "^5.16.0",
    "globals": "^17.4.0",
    "postcss-hover-media-feature": "^1.0.2",
    "prettier": "3.8.1",
    "sharp": "^0.34.5",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "webpack-filter-warnings-plugin": "^1.2.1"
  },
  "dependencies": {
    "@csstools/postcss-global-data": "^4.0.0",
    "@paypal/react-paypal-js": "^8.9.2",
    "@reduxjs/toolkit": "^2.11.2",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.0",
    "gatsby": "^5.16.1",
    "gatsby-omni-font-loader": "^2.0.2",
    "gatsby-plugin-dts-css-modules": "^3.0.0",
    "gatsby-plugin-image": "^3.16.0",
    "gatsby-plugin-postcss": "^6.16.0",
    "gatsby-plugin-robots-txt": "^1.8.0",
    "gatsby-plugin-root-import": "^2.0.9",
    "gatsby-plugin-sharp": "^5.16.0",
    "gatsby-remark-external-links": "^0.0.4",
    "gatsby-remark-images": "^7.16.0",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-remark": "^6.16.0",
    "gatsby-transformer-sharp": "^5.16.0",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "postcss": "^8.5.8",
    "postcss-custom-media": "^12.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet": "^6.1.0",
    "react-redux": "^9.2.0",
    "react-social-media-embed": "^2.5.18",
    "simple-oauth2": "^5.1.0"
  },
  "resolutions": {
    "cookie": "^0.7.0",
    "path-to-regexp": "^0.1.13"
  }
}
